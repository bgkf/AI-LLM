{
  "name": "code-review-mcp-server",
  "version": "1.0.0",
  "description": "Claude Code sub-agent for automated code review",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild ./src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:@anthropic-ai/sdk --external:@modelcontextprotocol/sdk --external:zod --format=cjs",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
